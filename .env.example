# ───────────────────────────────────────────────────────────────
# RaktSetu Backend — Environment Configuration
# Copy this file to ".env" and fill in real values before running.
# ───────────────────────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# CORS — the URL of your Next.js frontend (comma-separate multiple origins)
CLIENT_URL=http://localhost:4028

# ── Database ──────────────────────────────────────────────────
# Local MongoDB:    mongodb://127.0.0.1:27017/raktsetu
# MongoDB Atlas:    mongodb+srv://<user>:<pass>@cluster.xxxxx.mongodb.net/raktsetu
MONGO_URI=mongodb://127.0.0.1:27017/raktsetu

# If true, the server runs WITHOUT MongoDB using an in-memory mock store.
# Great for quick demos / deploying a preview before your DB is ready.
# Set to "false" in production once MONGO_URI is configured.
USE_MOCK=true

# ── Auth ──────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_EXPIRES_IN=7d

# ── AI Layer ──────────────────────────────────────────────────
# AI_MODE controls the donor-match, eligibility, forecasting & triage engines.
#   rules      → deterministic, offline rule-based AI (no API key needed) [DEFAULT]
#   openai     → uses OpenAI (set OPENAI_API_KEY)
#   anthropic  → uses Anthropic Claude (set ANTHROPIC_API_KEY)
# You can ship with "rules" and flip to a real LLM later WITHOUT code changes.
AI_MODE=rules

# Only needed when AI_MODE=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Only needed when AI_MODE=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
